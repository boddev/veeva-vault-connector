###############################################################################
# Veeva Vault Copilot Connector — Setup Configuration
#
# Copy this file to .env and fill in the values before running setup.
#   cp .env.template .env
#
# Lines starting with # are comments. Blank values will use defaults.
###############################################################################

# ─── Azure Subscription ─────────────────────────────────────────────────────
# The Azure subscription ID where resources will be created.
AZURE_SUBSCRIPTION_ID=

# Azure region for all resources (e.g., eastus, westus2, westeurope)
AZURE_LOCATION=eastus

# ─── Resource Naming ────────────────────────────────────────────────────────
# These names are auto-derived from VAULT_APPLICATION if left blank.
# Resource group name
AZURE_RESOURCE_GROUP=
# Storage account name (3–24 chars, lowercase alphanumeric only)
AZURE_STORAGE_ACCOUNT=
# App Service Plan name
AZURE_APP_SERVICE_PLAN=
# Function App name (must be globally unique)
AZURE_FUNCTION_APP=
# Application Insights name (leave blank to skip)
AZURE_APP_INSIGHTS=

# App Service Plan SKU: EP1, EP2, EP3 (Premium) or P1v3, P2v3, P3v3 (Dedicated)
AZURE_PLAN_SKU=EP1

# ─── Entra ID (Azure AD) ───────────────────────────────────────────────────
# If you already have an Entra ID app registration, enter its details below.
# Leave AZURE_CLIENT_ID blank to have the setup script create one automatically.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
SECRET_AZURE_CLIENT_SECRET=

# ─── Key Vault ──────────────────────────────────────────────────────────────
# Set to "true" (default) to create a Key Vault and store secrets there.
# Set to "false" for dev/test to store secrets directly in app settings.
USE_KEY_VAULT=true
# Key Vault name (auto-derived if blank)
AZURE_KEY_VAULT=

# ─── Veeva Vault ────────────────────────────────────────────────────────────
# Your Veeva Vault hostname (e.g., mycompany-promomats.veevavault.com)
VEEVA_VAULT_DNS=
# Vault API user credentials
VEEVA_USERNAME=
SECRET_VEEVA_PASSWORD=
# Veeva API version
VEEVA_API_VERSION=v25.3

# ─── Connector Settings ────────────────────────────────────────────────────
# Which Veeva application to index: promomats, qualitydocs, or rim
VAULT_APPLICATION=promomats

# Microsoft Graph API version: v1.0 (stable) or beta (preview features)
GRAPH_API_VERSION=v1.0

# ─── Crawl Configuration ───────────────────────────────────────────────────
# Days for full crawls (0=Sun through 6=Sat, comma-separated). Empty = every day.
FULL_CRAWL_DAYS=0,6
# CRON schedule for full crawl timer
FULL_CRAWL_SCHEDULE=0 0 2 * * *
# CRON schedule for incremental crawl
INCREMENTAL_CRAWL_SCHEDULE=0 */15 * * * *
# Items per processing batch
CRAWL_BATCH_SIZE=25
# Items per progress checkpoint
PROGRESS_BATCH_SIZE=500
# Auto-discover custom Vault objects
AUTO_DISCOVER_OBJECTS=true

# ─── Optional Overrides ────────────────────────────────────────────────────
# Override auto-generated connector ID/name/description
CONNECTOR_ID=
CONNECTOR_NAME=
CONNECTOR_DESCRIPTION=

# ─── M365 Agents (Optional) ────────────────────────────────────────────────
# Set to "true" to deploy M365 Copilot agents after connector setup
DEPLOY_M365_AGENTS=false
